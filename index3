<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>LiveDish AI — AR Menu Experience</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --gold:#C9A84C;--gold2:#E8C97A;--gold3:#F5E4B0;
  --dark:#07080F;--dark2:#0D0F1A;--dark3:#131627;
  --text:#F0F0F8;--muted:#6B7299;--muted2:#8890B5;
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--dark);color:var(--text);overflow-x:hidden;cursor:none}

.cursor-dot{width:8px;height:8px;background:white;border-radius:50%;position:fixed;top:0;left:0;transform:translate(-50%,-50%);pointer-events:none;z-index:9999;transition:transform .1s}
.cursor-ring{width:40px;height:40px;border:1px solid rgba(255,255,255,.4);border-radius:50%;position:fixed;top:0;left:0;transform:translate(-50%,-50%);pointer-events:none;z-index:9998;transition:width .3s,height .3s,border-color .3s}
.cursor-ring.expand{width:70px;height:70px;border-color:var(--gold)}

#particleCanvas{position:fixed;inset:0;z-index:-1;opacity:.6}

body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");opacity:.35;z-index:-1;pointer-events:none}

nav{position:fixed;top:0;left:0;right:0;height:76px;display:flex;justify-content:space-between;align-items:center;padding:0 5%;z-index:1000;transition:.4s}
nav.scrolled{background:rgba(7,8,15,.85);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,.05)}
.logo{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;letter-spacing:-1px;display:flex;align-items:center;gap:10px}
.logo-dot{width:8px;height:8px;background:var(--gold);border-radius:50%;animation:pulse 2s infinite}
.logo em{font-style:normal;color:var(--gold)}
.nav-links{display:flex;gap:36px}
.nav-links a{color:var(--muted2);text-decoration:none;font-size:13px;letter-spacing:.3px;transition:.3s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:1px;background:var(--gold);transition:.3s}
.nav-links a:hover{color:white}.nav-links a:hover::after{width:100%}
.nav-cta{background:transparent;border:1px solid rgba(201,168,76,.4);color:var(--gold);padding:12px 28px;border-radius:100px;font-size:13px;font-weight:500;cursor:none;transition:.3s;letter-spacing:.5px;font-family:'DM Sans',sans-serif}
.nav-cta:hover{background:var(--gold);color:black;transform:translateY(-1px)}

.hero{min-height:100vh;display:flex;align-items:center;padding:0 5%;position:relative;overflow:hidden}
.hero-content{max-width:900px;position:relative;z-index:2}
.hero-badge{display:inline-flex;align-items:center;gap:8px;padding:8px 20px;border:1px solid rgba(201,168,76,.25);border-radius:100px;color:var(--gold);font-size:11px;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:36px;background:rgba(201,168,76,.04);opacity:0;animation:slideIn .8s .2s forwards}
.hero-badge-dot{width:6px;height:6px;background:var(--gold);border-radius:50%;animation:pulse 1.5s infinite}
.hero h1{font-family:'Syne',sans-serif;font-size:clamp(52px,8.5vw,118px);line-height:.9;font-weight:800;letter-spacing:-4px;opacity:0;animation:slideIn .8s .4s forwards}
.hero h1 .outline{color:transparent;-webkit-text-stroke:1.5px var(--gold);display:block}
.hero h1 .solid{display:block}
.hero-sub{margin:32px 0 48px;color:var(--muted2);font-size:17px;line-height:1.9;max-width:560px;font-weight:300;opacity:0;animation:slideIn .8s .6s forwards}
.hero-actions{display:flex;gap:18px;flex-wrap:wrap;opacity:0;animation:slideIn .8s .8s forwards}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold2));color:black;padding:17px 36px;border:none;border-radius:100px;font-weight:600;cursor:none;transition:.35s;font-size:14px;letter-spacing:.3px;position:relative;overflow:hidden;font-family:'DM Sans',sans-serif}
.btn-gold::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--gold2),var(--gold3));opacity:0;transition:.35s}
.btn-gold:hover::before{opacity:1}
.btn-gold:hover{transform:translateY(-3px);box-shadow:0 20px 50px rgba(201,168,76,.25)}
.btn-gold span{position:relative;z-index:1}
.btn-ghost{background:transparent;color:white;border:1px solid rgba(255,255,255,.12);padding:17px 36px;border-radius:100px;font-weight:400;cursor:none;transition:.35s;font-size:14px;display:flex;align-items:center;gap:10px;font-family:'DM Sans',sans-serif}
.btn-ghost:hover{border-color:rgba(201,168,76,.4);color:var(--gold)}
.hero-stats{position:absolute;right:5%;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:24px;opacity:0;animation:fadeIn .8s 1.2s forwards}
.stat-item{text-align:right}
.stat-num{font-family:'Syne',sans-serif;font-size:42px;font-weight:800;color:white;line-height:1}
.stat-num em{color:var(--gold);font-style:normal}
.stat-label{font-size:11px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-top:4px}
.stat-line{width:1px;height:40px;background:rgba(255,255,255,.08);margin-left:auto}
.scroll-hint{position:absolute;bottom:48px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:10px;opacity:0;animation:fadeIn 1s 1.5s forwards}
.scroll-hint span{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--muted)}
.scroll-line{width:1px;height:50px;background:linear-gradient(to bottom, var(--gold), transparent);animation:scrollAnim 2s infinite}

.ar-demo{padding:130px 5%;display:grid;grid-template-columns:1fr 1fr;gap:100px;align-items:center}
.ar-left{position:relative}
.ar-label{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:24px;opacity:0;transform:translateY(20px);transition:.8s}
.ar-left h2{font-family:'Syne',sans-serif;font-size:clamp(36px,4.5vw,60px);line-height:1.05;font-weight:800;letter-spacing:-2px;margin-bottom:28px;opacity:0;transform:translateY(20px);transition:.8s .1s}
.ar-left p{color:var(--muted2);font-size:16px;line-height:1.9;font-weight:300;max-width:480px;margin-bottom:40px;opacity:0;transform:translateY(20px);transition:.8s .2s}
.ar-chips{display:flex;gap:12px;flex-wrap:wrap;opacity:0;transform:translateY(20px);transition:.8s .3s}
.ar-left.visible .ar-label,.ar-left.visible h2,.ar-left.visible p,.ar-left.visible .ar-chips{opacity:1;transform:none}
.chip{padding:10px 20px;border-radius:100px;border:1px solid rgba(201,168,76,.2);background:rgba(201,168,76,.04);color:var(--gold2);font-size:12px;letter-spacing:.5px;transition:.3s;cursor:none}
.chip:hover,.chip.active-chip{background:rgba(201,168,76,.12);border-color:rgba(201,168,76,.5);color:white}

.phone-wrap{display:flex;justify-content:center;position:relative}
.phone-aura{position:absolute;width:320px;height:320px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,.1),transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);animation:aura 4s ease-in-out infinite}
.phone{width:295px;height:630px;border-radius:50px;background:linear-gradient(170deg,#0E1020,#090B14);border:1.5px solid rgba(255,255,255,.1);position:relative;overflow:hidden;box-shadow:0 60px 120px rgba(0,0,0,.7),0 0 0 1px rgba(255,255,255,.04),inset 0 0 40px rgba(201,168,76,.03);animation:phoneFloat 5s ease-in-out infinite}
.phone-notch{width:100px;height:26px;background:black;border-radius:0 0 18px 18px;position:absolute;top:0;left:50%;transform:translateX(-50%);z-index:10}
.phone-inner{padding:36px 20px 24px;height:100%;display:flex;flex-direction:column}
.phone-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:22px;margin-top:10px}
.phone-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--gold);letter-spacing:1.5px}
.live-pill{font-size:10px;color:var(--gold);border:1px solid rgba(201,168,76,.3);padding:4px 12px;border-radius:20px;display:flex;align-items:center;gap:6px}
.live-dot{width:5px;height:5px;background:var(--gold);border-radius:50%;animation:pulse 1s infinite}
.scan-area{flex:1;border-radius:24px;border:1px solid rgba(201,168,76,.15);background:rgba(255,255,255,.02);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;margin-bottom:20px}
.corner{position:absolute;width:24px;height:24px;border-color:var(--gold);border-style:solid}
.c-tl{top:16px;left:16px;border-width:2px 0 0 2px;border-radius:4px 0 0 0}
.c-tr{top:16px;right:16px;border-width:2px 2px 0 0;border-radius:0 4px 0 0}
.c-bl{bottom:16px;left:16px;border-width:0 0 2px 2px;border-radius:0 0 0 4px}
.c-br{bottom:16px;right:16px;border-width:0 2px 2px 0;border-radius:0 0 4px 0}
.scan-beam{position:absolute;width:85%;height:1.5px;background:linear-gradient(90deg,transparent,var(--gold),transparent);left:7.5%;box-shadow:0 0 16px var(--gold);animation:beam 2.5s ease-in-out infinite}
.dish-display{font-size:90px;filter:drop-shadow(0 16px 32px rgba(201,168,76,.25));animation:dishFloat 3.5s ease-in-out infinite;transition:opacity .3s,transform .3s}
.dish-name{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;text-align:center;margin-bottom:10px;transition:opacity .3s}
.dish-meta{display:flex;justify-content:center;gap:7px;flex-wrap:wrap;margin-bottom:16px}
.meta-tag{font-size:10px;padding:5px 12px;border-radius:20px;border:1px solid rgba(201,168,76,.18);background:rgba(201,168,76,.05);color:var(--gold2);letter-spacing:.3px}
.order-bar{display:flex;justify-content:space-between;align-items:center;background:linear-gradient(135deg,var(--gold),var(--gold2));border-radius:60px;padding:16px 22px;cursor:none}
.order-bar span:first-child{font-weight:600;font-size:13px;color:black}
.order-price{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:black}
.nav-dots{display:flex;gap:6px;justify-content:center;margin-top:14px}
.nav-dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.15);transition:.3s;cursor:none}
.nav-dot.active{background:var(--gold);width:18px;border-radius:4px}

.marquee-wrap{padding:56px 0;overflow:hidden;border-top:1px solid rgba(255,255,255,.04);border-bottom:1px solid rgba(255,255,255,.04)}
.marquee{display:flex;gap:0;animation:marquee 22s linear infinite}
.marquee-track{display:flex;gap:80px;align-items:center;padding-right:80px;white-space:nowrap}
.m-item{font-family:'Syne',sans-serif;font-size:13px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:20px}
.m-dot{width:5px;height:5px;background:var(--gold);border-radius:50%;flex-shrink:0}

.features{padding:130px 5%}
.section-head{text-align:center;margin-bottom:90px}
.section-tag{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:20px}
.section-head h2{font-family:'Syne',sans-serif;font-size:clamp(40px,5.5vw,72px);font-weight:800;letter-spacing:-3px;line-height:.95}
.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.feat{background:var(--dark2);padding:52px 40px;position:relative;overflow:hidden;opacity:0;transform:translateY(30px);transition:.7s;cursor:none}
.feat:nth-child(1){border-radius:24px 0 0 0}
.feat:nth-child(3){border-radius:0 24px 0 0}
.feat:nth-child(4){border-radius:0 0 0 24px}
.feat:nth-child(6){border-radius:0 0 24px 0}
.feat::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at top left,rgba(201,168,76,.07),transparent 50%);opacity:0;transition:.4s}
.feat:hover::before{opacity:1}
.feat:hover{background:#0F1122}
.feat.visible{opacity:1;transform:none}
.feat-num{font-family:'Syne',sans-serif;font-size:11px;letter-spacing:3px;color:rgba(201,168,76,.35);margin-bottom:28px}
.feat-icon-wrap{width:60px;height:60px;border-radius:16px;background:rgba(201,168,76,.07);border:1px solid rgba(201,168,76,.15);display:flex;align-items:center;justify-content:center;font-size:26px;margin-bottom:28px;transition:.4s}
.feat:hover .feat-icon-wrap{background:rgba(201,168,76,.12);transform:scale(1.05)}
.feat h3{font-family:'Syne',sans-serif;font-size:21px;font-weight:700;margin-bottom:14px;letter-spacing:-.5px}
.feat p{color:var(--muted2);font-size:14px;line-height:1.85;font-weight:300}
.feat-arrow{position:absolute;bottom:40px;right:40px;width:38px;height:38px;border-radius:50%;border:1px solid rgba(201,168,76,.2);display:flex;align-items:center;justify-content:center;color:var(--gold);font-size:16px;transition:.4s;opacity:0}
.feat:hover .feat-arrow{opacity:1;transform:translateX(3px)}

.process{padding:130px 5%;background:var(--dark2)}
.process-inner{max-width:1200px;margin:0 auto}
.process-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;margin-top:90px;background:rgba(255,255,255,.05);border-radius:24px;overflow:hidden}
.step{background:var(--dark2);padding:50px 36px;position:relative;opacity:0;transform:translateY(20px);transition:.6s}
.step.visible{opacity:1;transform:none}
.step-num{font-family:'Syne',sans-serif;font-size:64px;font-weight:800;color:rgba(201,168,76,.06);line-height:1;margin-bottom:20px}
.step-icon{font-size:32px;margin-bottom:18px}
.step h3{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;margin-bottom:12px;letter-spacing:-.3px}
.step p{color:var(--muted2);font-size:13px;line-height:1.8;font-weight:300}
.step-bar{height:2px;width:0;background:linear-gradient(90deg,var(--gold),var(--gold2));margin-bottom:28px;transition:width 1s .5s;border-radius:2px}
.step.visible .step-bar{width:100%}

.numbers{padding:130px 5%}
.numbers-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-top:80px;background:rgba(255,255,255,.04);border-radius:24px;overflow:hidden}
.num-block{background:var(--dark);padding:60px 40px;text-align:center}
.num-value{font-family:'Syne',sans-serif;font-size:clamp(42px,5vw,68px);font-weight:800;letter-spacing:-3px;line-height:1}
.num-value em{color:var(--gold);font-style:normal}
.num-label{color:var(--muted2);font-size:12px;letter-spacing:2px;text-transform:uppercase;margin-top:12px;font-weight:300}

.cta-section{padding:130px 5%}
.cta-box{background:var(--dark2);border-radius:32px;padding:110px 60px;text-align:center;border:1px solid rgba(201,168,76,.1);position:relative;overflow:hidden}
.cta-glow{position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,.07),transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.cta-box h2{font-family:'Syne',sans-serif;font-size:clamp(40px,6vw,80px);font-weight:800;letter-spacing:-3px;line-height:.95;position:relative;z-index:2;margin-bottom:28px}
.cta-box h2 em{font-style:italic;color:var(--gold)}
.cta-box p{color:var(--muted2);font-size:17px;font-weight:300;line-height:1.8;max-width:580px;margin:0 auto 48px;position:relative;z-index:2}
.cta-buttons{display:flex;justify-content:center;gap:18px;position:relative;z-index:2;flex-wrap:wrap}
.cta-ring{position:absolute;border:1px solid rgba(201,168,76,.08);border-radius:50%;pointer-events:none}
.cta-ring:nth-child(1){width:400px;height:400px;top:50%;left:50%;transform:translate(-50%,-50%);animation:ringPulse 3s infinite}
.cta-ring:nth-child(2){width:600px;height:600px;top:50%;left:50%;transform:translate(-50%,-50%);animation:ringPulse 3s 1s infinite}
.cta-ring:nth-child(3){width:800px;height:800px;top:50%;left:50%;transform:translate(-50%,-50%);animation:ringPulse 3s 2s infinite}

footer{padding:60px 5%;border-top:1px solid rgba(255,255,255,.05);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:24px}
.footer-logo{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;letter-spacing:-1px}
.footer-logo em{font-style:normal;color:var(--gold)}
.footer-links{display:flex;gap:32px}
.footer-links a{color:var(--muted);font-size:13px;text-decoration:none;transition:.3s}
.footer-links a:hover{color:white}
.footer-right{color:var(--muted);font-size:12px;letter-spacing:.5px}

@keyframes slideIn{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}
@keyframes scrollAnim{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}
@keyframes beam{0%{top:10px;opacity:0}15%{opacity:1}85%{opacity:1}100%{top:calc(100% - 20px);opacity:0}}
@keyframes dishFloat{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-12px) rotate(4deg)}}
@keyframes phoneFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
@keyframes aura{0%,100%{transform:translate(-50%,-50%) scale(1);opacity:.5}50%{transform:translate(-50%,-50%) scale(1.2);opacity:.25}}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
@keyframes ringPulse{0%{opacity:.6;transform:translate(-50%,-50%) scale(.9)}100%{opacity:0;transform:translate(-50%,-50%) scale(1.15)}}

@media(max-width:1024px){
  .hero-stats{display:none}
  .ar-demo{grid-template-columns:1fr;gap:60px}
  .features-grid{grid-template-columns:1fr 1fr}
  .process-steps{grid-template-columns:repeat(2,1fr)}
  .numbers-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:768px){
  .nav-links{display:none}
  .hero h1{letter-spacing:-2px}
  .features-grid{grid-template-columns:1fr}
  .cta-box{padding:70px 28px}
  .feat:nth-child(n){border-radius:0}
  .feat:first-child{border-radius:16px 16px 0 0}
  .feat:last-child{border-radius:0 0 16px 16px}
}
</style>
</head>
<body>

<div class="cursor-dot" id="dot"></div>
<div class="cursor-ring" id="ring"></div>
<canvas id="particleCanvas"></canvas>

<nav id="nav">
  <div class="logo">
    <span class="logo-dot"></span>
    Live<em>Dish</em> AI
  </div>
  <div class="nav-links">
    <a href="#features">Features</a>
    <a href="#process">How It Works</a>
    <a href="#numbers">Results</a>
    <a href="#">Pricing</a>
  </div>
  <button class="nav-cta">Book a Demo</button>
</nav>

<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">
      <span class="hero-badge-dot"></span>
      Augmented Reality Dining
    </div>
    <h1>
      <span class="solid">See Before</span>
      <span class="outline">You Order</span>
    </h1>
    <p class="hero-sub">LiveDish AI brings your menu to life. Guests scan a dish, see a photorealistic 3D preview on their table, and order with complete confidence.</p>
    <div class="hero-actions">
      <button class="btn-gold"><span>Experience the Demo →</span></button>
      <button class="btn-ghost">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polygon points="10,8 16,12 10,16" fill="currentColor" stroke="none"/></svg>
        Watch 90-sec Film
      </button>
    </div>
  </div>
  <div class="hero-stats">
    <div class="stat-item">
      <div class="stat-num"><span class="hero-count" data-target="340">0</span><em>%</em></div>
      <div class="stat-label">Upsell Increase</div>
    </div>
    <div class="stat-line"></div>
    <div class="stat-item">
      <div class="stat-num"><span class="hero-count" data-target="48">0</span><em>hr</em></div>
      <div class="stat-label">Go-Live Timeline</div>
    </div>
    <div class="stat-line"></div>
    <div class="stat-item">
      <div class="stat-num"><span class="hero-count" data-target="98">0</span><em>%</em></div>
      <div class="stat-label">Diner Satisfaction</div>
    </div>
  </div>
  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<div class="marquee-wrap">
  <div class="marquee">
    <div class="marquee-track" id="mt1">
      <span class="m-item"><span class="m-dot"></span>WebAR Technology</span>
      <span class="m-item"><span class="m-dot"></span>Zero App Install</span>
      <span class="m-item"><span class="m-dot"></span>Real-Time 3D Preview</span>
      <span class="m-item"><span class="m-dot"></span>Allergen Alerts</span>
      <span class="m-item"><span class="m-dot"></span>Instant QR Ordering</span>
      <span class="m-item"><span class="m-dot"></span>AI Recommendations</span>
      <span class="m-item"><span class="m-dot"></span>Multi-Language Support</span>
