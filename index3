<script>
/* CURSOR */
const dot=document.getElementById('dot'),ring=document.getElementById('ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;dot.style.left=mx+'px';dot.style.top=my+'px'});
document.querySelectorAll('button,a,.chip,.nav-dot').forEach(el=>{
  el.addEventListener('mouseenter',()=>ring.classList.add('expand'));
  el.addEventListener('mouseleave',()=>ring.classList.remove('expand'));
});
(function animRing(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(animRing)})();

/* PARTICLES */
const canvas=document.getElementById('particleCanvas'),ctx=canvas.getContext('2d');
let W,H;
function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight}
resize();window.addEventListener('resize',resize);
class P{
  constructor(){this.reset()}
  reset(){this.x=Math.random()*W;this.y=Math.random()*H;this.r=Math.random()*1.4+.3;this.vx=(Math.random()-.5)*.25;this.vy=(Math.random()-.5)*.25;this.a=Math.random()*.45+.05}
  update(){this.x+=this.vx;this.y+=this.vy;if(this.x<0||this.x>W||this.y<0||this.y>H)this.reset()}
  draw(){ctx.beginPath();ctx.arc(this.x,this.y,this.r,0,Math.PI*2);ctx.fillStyle=`rgba(201,168,76,${this.a})`;ctx.fill()}
}
const particles=Array.from({length:100},()=>new P());
function animP(){ctx.clearRect(0,0,W,H);particles.forEach(p=>{p.update();p.draw()});requestAnimationFrame(animP)}
animP();

/* NAV */
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>60));

/* DISHES */
const dishes=[
  {emoji:'🍣',name:'Sushi Omakase',price:'₹1,290',tags:['🔥 580 kcal','⭐ 4.9','🌿 Raw','🚫 Gluten-Free']},
  {emoji:'🍔',name:'Truffle Smash Burger',price:'₹680',tags:['🔥 920 kcal','⭐ 4.8','🧀 Cheese','🥩 Wagyu']},
  {emoji:'🍕',name:'Truffle White Pizza',price:'₹890',tags:['🔥 740 kcal','⭐ 4.7','🍄 Mushroom','🧄 Garlic']},
  {emoji:'🍜',name:'Tonkotsu Ramen',price:'₹540',tags:['🔥 680 kcal','⭐ 4.9','🥚 Soft Egg','🌶 Spicy']},
  {emoji:'🥗',name:'Caesar Deluxe',price:'₹420',tags:['🔥 280 kcal','⭐ 4.6','🌿 Vegan','💪 Protein']},
  {emoji:'🍛',name:'Lamb Rogan Josh',price:'₹780',tags:['🔥 650 kcal','⭐ 4.8','🌶 Bold Spice','🫙 Slow Cooked']}
];
let current=0,autoPlay;
function switchDish(i,chipEl){
  clearInterval(autoPlay);
  current=i;
  if(chipEl){
    document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active-chip'));
    chipEl.classList.add('active-chip');
  } else {
    document.querySelectorAll('.chip').forEach((c,idx)=>c.classList.toggle('active-chip',idx===i));
  }
  const d=dishes[i];
  const em=document.getElementById('dishEmoji');
  em.style.opacity='0';em.style.transform='scale(.75)';
  setTimeout(()=>{
    em.textContent=d.emoji;
    document.getElementById('dishName').textContent=d.name;
    document.getElementById('dishPrice').textContent=d.price;
    document.getElementById('dishMeta').innerHTML=d.tags.map(t=>`<span class="meta-tag">${t}</span>`).join('');
    document.querySelectorAll('.nav-dot').forEach((dot,idx)=>dot.classList.toggle('active',idx===i));
    em.style.opacity='1';em.style.transform='';
  },260);
  startAuto();
}
function startAuto(){autoPlay=setInterval(()=>{current=(current+1)%dishes.length;switchDish(current,null)},3800)}
startAuto();

/* OBSERVERS */
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target)}});
},{threshold:.12});
document.querySelectorAll('.feat,.ar-left').forEach(el=>obs.observe(el));

const stepObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      document.querySelectorAll('.step').forEach((s,i)=>setTimeout(()=>s.classList.add('visible'),i*140));
      stepObs.disconnect();
    }
  });
},{threshold:.15});
document.querySelectorAll('.step').forEach(s=>stepObs.observe(s));

/* COUNT UP */
const cObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(!e.isIntersecting)return;
    const el=e.target,target=+el.dataset.target;
    let start=null;
    const run=ts=>{
      if(!start)start=ts;
      const p=Math.min((ts-start)/1900,1);
      const ease=1-Math.pow(1-p,3);
      el.textContent=Math.round(ease*target).toLocaleString();
      if(p<1)requestAnimationFrame(run);
    };
    requestAnimationFrame(run);
    cObs.unobserve(el);
  });
},{threshold:.5});
document.querySelectorAll('.count-up').forEach(el=>cObs.observe(el));

/* HERO STATS */
setTimeout(()=>{
  document.querySelectorAll('.hero-count').forEach(el=>{
    const target=+el.dataset.target;let s=null;
    const run=ts=>{if(!s)s=ts;const p=Math.min((ts-s)/1600,1);const e=1-Math.pow(1-p,3);el.textContent=Math.round(e*target).toLocaleString();if(p<1)requestAnimationFrame(run)};
    requestAnimationFrame(run);
  });
},1400);
</script>
