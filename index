<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>LiveDish AI — The Future of Restaurant Menus</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --gold:#C9A84C;--gold2:#E8C97A;--gold3:#F5E4B5;
  --dark:#060810;--dark2:#0A0C18;--dark3:#0E1020;--mid:#141628;
  --text:#F4F4FF;--muted:#8890B0;--faint:#3A3D58;
  --border:rgba(201,168,76,0.15);--border2:rgba(201,168,76,0.08);
  --rad:12px;--radlg:20px;
  --glow:rgba(201,168,76,0.12);
}
html{scroll-behavior:smooth;}
body{font-family:'Inter',sans-serif;background:var(--dark);color:var(--text);overflow-x:hidden;}

/* PARTICLES */
#canvas-bg{position:fixed;inset:0;z-index:0;pointer-events:none;}

/* GRAIN OVERLAY */
.grain{position:fixed;inset:0;z-index:1;pointer-events:none;opacity:0.025;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");}

/* PROGRESS BAR */
.prog{position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,var(--gold),var(--gold2));z-index:999;transition:width .1s;box-shadow:0 0 12px var(--gold);}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:500;height:76px;padding:0 6%;display:flex;align-items:center;justify-content:space-between;background:rgba(6,8,16,0.7);backdrop-filter:blur(24px);border-bottom:1px solid var(--border2);}
.nav-logo{display:flex;align-items:center;gap:12px;}
.logo-mark{width:36px;height:36px;border-radius:8px;border:1.5px solid var(--gold);display:flex;align-items:center;justify-content:center;font-size:18px;background:rgba(201,168,76,0.06);}
.logo-name{font-size:18px;font-weight:800;letter-spacing:-0.5px;color:var(--text);}
.logo-name span{color:var(--gold);}
.nav-links{display:flex;gap:36px;list-style:none;}
.nav-links a{font-size:13px;font-weight:500;color:var(--muted);text-decoration:none;letter-spacing:0.3px;transition:color .2s;}
.nav-links a:hover{color:var(--text);}
.nav-pill{display:flex;align-items:center;gap:8px;}
.nav-book{background:transparent;border:1px solid var(--border);color:var(--muted);padding:9px 20px;border-radius:50px;font-size:13px;font-weight:500;cursor:pointer;transition:all .2s;}
.nav-book:hover{border-color:var(--gold);color:var(--gold);}
.nav-demo{background:var(--gold);color:var(--dark);padding:9px 22px;border-radius:50px;font-size:13px;font-weight:700;border:none;cursor:pointer;transition:all .2s;letter-spacing:0.2px;}
.nav-demo:hover{background:var(--gold2);transform:translateY(-1px);}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:140px 6% 100px;position:relative;z-index:2;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:10px;border:1px solid var(--border);border-radius:50px;padding:6px 18px 6px 8px;font-size:12px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);margin-bottom:36px;background:rgba(201,168,76,0.04);}
.eyebrow-dot{width:24px;height:24px;border-radius:50%;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.3);display:flex;align-items:center;justify-content:center;font-size:10px;}
.hero h1{font-size:clamp(48px,7.5vw,96px);font-weight:900;line-height:0.95;letter-spacing:-3px;max-width:1000px;margin:0 auto;}
.h1-line{display:block;color:var(--text);}
.h1-gold{display:block;color:transparent;-webkit-text-stroke:1.5px var(--gold);letter-spacing:-3px;}
.h1-solid{display:block;color:var(--text);}
.hero-sub{font-size:clamp(15px,1.8vw,18px);color:var(--muted);max-width:520px;margin:32px auto 0;line-height:1.85;font-weight:400;}
.hero-cta{display:flex;gap:14px;margin-top:52px;flex-wrap:wrap;justify-content:center;}
.cta-primary{background:var(--gold);color:var(--dark);padding:16px 36px;border-radius:50px;font-size:15px;font-weight:700;border:none;cursor:pointer;transition:all .3s;letter-spacing:0.3px;box-shadow:0 0 40px rgba(201,168,76,0.2);}
.cta-primary:hover{background:var(--gold2);transform:translateY(-3px);box-shadow:0 0 60px rgba(201,168,76,0.35);}
.cta-secondary{background:transparent;color:var(--text);padding:16px 36px;border-radius:50px;font-size:15px;font-weight:500;border:1px solid var(--faint);cursor:pointer;transition:all .3s;display:flex;align-items:center;gap:10px;}
.cta-secondary:hover{border-color:var(--gold);color:var(--gold);transform:translateY(-2px);}
.hero-scroll{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;opacity:.4;}
.scroll-line{width:1px;height:50px;background:linear-gradient(to bottom,var(--gold),transparent);animation:scrollPulse 2s ease-in-out infinite;}
@keyframes scrollPulse{0%,100%{opacity:0.4;transform:scaleY(1);}50%{opacity:1;transform:scaleY(1.1);}}
.scroll-txt{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);}

/* MARQUEE STRIP */
.marquee-wrap{position:relative;z-index:2;border-top:1px solid var(--border2);border-bottom:1px solid var(--border2);padding:18px 0;overflow:hidden;background:rgba(201,168,76,0.02);}
.marquee-track{display:flex;gap:0;animation:marqueeSlide 25s linear infinite;width:max-content;}
.marquee-item{display:flex;align-items:center;gap:10px;padding:0 40px;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);border-right:1px solid var(--border2);white-space:nowrap;}
.marquee-item span{color:var(--gold);font-weight:700;}
@keyframes marqueeSlide{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* METRICS SECTION */
.metrics{padding:100px 6%;position:relative;z-index:2;}
.metrics-inner{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border2);border-radius:var(--radlg);overflow:hidden;border:1px solid var(--border2);}
.metric-card{background:var(--dark2);padding:48px 32px;text-align:center;position:relative;overflow:hidden;transition:background .3s;}
.metric-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:0;transition:opacity .3s;}
.metric-card:hover{background:var(--dark3);}
.metric-card:hover::before{opacity:1;}
.metric-val{font-size:52px;font-weight:900;letter-spacing:-2px;color:var(--gold);line-height:1;font-variant-numeric:tabular-nums;}
.metric-unit{font-size:22px;vertical-align:super;}
.metric-lbl{font-size:13px;color:var(--muted);margin-top:10px;font-weight:400;line-height:1.5;}
.metric-sub{font-size:11px;color:var(--faint);margin-top:4px;letter-spacing:0.5px;}

/* SECTION COMMONS */
section{padding:110px 6%;position:relative;z-index:2;}
.section-label{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:18px;}
.section-label::before{content:'';width:20px;height:1px;background:var(--gold);}
.section-h{font-size:clamp(32px,4vw,54px);font-weight:900;letter-spacing:-2px;line-height:1.05;color:var(--text);}
.section-p{font-size:16px;color:var(--muted);margin-top:18px;line-height:1.9;max-width:520px;}

/* DIVIDER */
.divider{width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);position:relative;z-index:2;}

/* HOW IT WORKS */
.how-sec{background:var(--dark2);}
.timeline{margin-top:72px;display:flex;flex-direction:column;gap:0;position:relative;}
.timeline::before{content:'';position:absolute;left:28px;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,var(--gold),var(--faint),transparent);}
.tl-item{display:grid;grid-template-columns:56px 1fr;gap:40px;padding:0 0 64px;position:relative;opacity:0;transform:translateY(20px);transition:all .6s ease;}
.tl-item.visible{opacity:1;transform:translateY(0);}
.tl-dot{width:56px;height:56px;border-radius:50%;background:var(--dark3);border:1px solid var(--gold);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:var(--gold);position:relative;z-index:1;flex-shrink:0;}
.tl-content{padding-top:14px;}
.tl-step{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:10px;}
.tl-h{font-size:22px;font-weight:800;letter-spacing:-0.5px;margin-bottom:10px;}
.tl-p{font-size:15px;color:var(--muted);line-height:1.8;max-width:560px;}
.tl-tags{display:flex;gap:8px;flex-wrap:wrap;margin-top:16px;}
.tl-tag{font-size:11px;padding:4px 12px;border-radius:50px;border:1px solid var(--border);color:var(--muted);background:rgba(201,168,76,0.03);}

/* FEATURES BENTO */
.bento{display:grid;grid-template-columns:repeat(12,1fr);grid-auto-rows:auto;gap:16px;margin-top:72px;}
.bento-card{background:var(--dark2);border:1px solid var(--border2);border-radius:var(--radlg);padding:36px;position:relative;overflow:hidden;transition:all .4s;cursor:default;}
.bento-card:hover{border-color:var(--border);background:var(--dark3);transform:translateY(-4px);}
.bento-card::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at var(--mx,50%) var(--my,50%),rgba(201,168,76,0.06) 0%,transparent 60%);opacity:0;transition:opacity .3s;pointer-events:none;}
.bento-card:hover::after{opacity:1;}
.bc1{grid-column:span 7;}
.bc2{grid-column:span 5;}
.bc3{grid-column:span 4;}
.bc4{grid-column:span 4;}
.bc5{grid-column:span 4;}
.bc6{grid-column:span 6;}
.bc7{grid-column:span 6;}
.b-ico{width:48px;height:48px;border-radius:12px;background:rgba(201,168,76,0.08);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:22px;transition:transform .3s;}
.bento-card:hover .b-ico{transform:scale(1.12) rotate(-6deg);}
.b-h{font-size:19px;font-weight:800;letter-spacing:-0.5px;margin-bottom:10px;}
.b-p{font-size:14px;color:var(--muted);line-height:1.75;}
.b-tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:16px;}
.b-tag{font-size:11px;padding:3px 10px;border-radius:50px;border:1px solid var(--border2);color:var(--faint);}
.b-metric{font-size:42px;font-weight:900;color:var(--gold);letter-spacing:-2px;margin:16px 0 6px;line-height:1;}
.b-metric-lbl{font-size:13px;color:var(--muted);}
.b-visual{margin-top:20px;height:5px;background:var(--faint);border-radius:50px;overflow:hidden;}
.b-bar{height:100%;border-radius:50px;background:linear-gradient(90deg,var(--gold),var(--gold2));animation:barGrow 1.5s ease both;}
@keyframes barGrow{from{width:0;}to{width:var(--w,70%);}}

/* AR SECTION */
.ar-section{background:var(--dark2);}
.ar-split{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;margin-top:64px;}
.ar-visual{position:relative;display:flex;justify-content:center;padding:40px 0;}

/* PHONE MOCKUP */
.phone{width:220px;height:460px;border-radius:40px;background:var(--dark3);border:2px solid var(--border);position:relative;overflow:hidden;box-shadow:0 60px 120px rgba(0,0,0,0.8),0 0 0 1px rgba(201,168,76,0.1) inset;}
.phone-bar{position:absolute;top:0;left:50%;transform:translateX(-50%);width:70px;height:22px;background:var(--dark);border-radius:0 0 14px 14px;z-index:2;}
.p-screen{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;padding:36px 16px 20px;}
.p-header{width:100%;display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.p-logo{font-size:11px;font-weight:800;color:var(--gold);letter-spacing:1px;}
.p-live{font-size:9px;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.3);color:var(--gold);padding:2px 8px;border-radius:50px;letter-spacing:1px;}
.p-ar-frame{width:160px;height:160px;border-radius:20px;position:relative;background:rgba(201,168,76,0.03);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden;}
.p-corners span{position:absolute;width:16px;height:16px;border-color:var(--gold);border-style:solid;}
.p-corners .tl{top:8px;left:8px;border-width:2px 0 0 2px;border-radius:3px 0 0 0;}
.p-corners .tr{top:8px;right:8px;border-width:2px 2px 0 0;border-radius:0 3px 0 0;}
.p-corners .bl{bottom:8px;left:8px;border-width:0 0 2px 2px;border-radius:0 0 0 3px;}
.p-corners .br{bottom:8px;right:8px;border-width:0 2px 2px 0;border-radius:0 0 3px 0;}
.p-dish{font-size:72px;line-height:1;animation:dishFloat 3s ease-in-out infinite;transition:opacity .3s;}
@keyframes dishFloat{0%,100%{transform:translateY(0) scale(1);}50%{transform:translateY(-12px) scale(1.06);}}
.p-scan-line{position:absolute;left:12px;right:12px;height:1.5px;background:linear-gradient(90deg,transparent,var(--gold),transparent);animation:scanV 2.4s ease-in-out infinite;}
@keyframes scanV{0%,100%{top:12px;opacity:0;}15%,85%{opacity:0.8;}50%{top:148px;}}
.p-info{width:100%;margin-top:14px;display:flex;flex-direction:column;gap:8px;}
.p-dish-name{font-size:14px;font-weight:700;text-align:center;color:var(--text);}
.p-pills{display:flex;gap:6px;justify-content:center;flex-wrap:wrap;}
.p-pill{font-size:9px;padding:3px 8px;border-radius:50px;background:rgba(201,168,76,0.08);border:1px solid var(--border);color:var(--gold);}
.p-btn{margin-top:10px;width:100%;padding:10px;background:var(--gold);color:var(--dark);border:none;border-radius:50px;font-size:12px;font-weight:800;cursor:pointer;letter-spacing:0.5px;}
.phone-glow{position:absolute;bottom:-30px;left:50%;transform:translateX(-50%);width:200px;height:100px;background:rgba(201,168,76,0.15);filter:blur(40px);border-radius:50%;pointer-events:none;}
.phone-rings{position:absolute;inset:0;pointer-events:none;}
.ring{position:absolute;left:50%;top:50%;border-radius:50%;border:1px solid rgba(201,168,76,0.1);transform:translate(-50%,-50%);animation:ringExpand 3s ease-out infinite;}
.ring:nth-child(2){animation-delay:-1s;}
.ring:nth-child(3){animation-delay:-2s;}
@keyframes ringExpand{0%{width:220px;height:220px;opacity:.4;}100%{width:500px;height:500px;opacity:0;}}
.ar-points{list-style:none;display:flex;flex-direction:column;gap:24px;}
.ap{display:flex;gap:18px;align-items:flex-start;}
.ap-n{width:32px;height:32px;border-radius:8px;background:rgba(201,168,76,0.06);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:var(--gold);flex-shrink:0;margin-top:2px;}
.ap-h{font-size:16px;font-weight:700;margin-bottom:5px;}
.ap-p{font-size:14px;color:var(--muted);line-height:1.7;}

/* INDUSTRIES */
.ind-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:64px;}
.ind-card{background:var(--dark2);border:1px solid var(--border2);border-radius:var(--radlg);padding:36px 28px;transition:all .3s;position:relative;overflow:hidden;}
.ind-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(201,168,76,0.04) 0%,transparent 60%);opacity:0;transition:opacity .3s;}
.ind-card:hover{border-color:var(--border);transform:translateY(-4px);}
.ind-card:hover::before{opacity:1;}
.ind-ico{font-size:32px;margin-bottom:18px;display:block;}
.ind-h{font-size:18px;font-weight:800;margin-bottom:8px;letter-spacing:-0.3px;}
.ind-p{font-size:14px;color:var(--muted);line-height:1.7;}
.ind-stat{margin-top:20px;font-size:24px;font-weight:900;color:var(--gold);letter-spacing:-1px;}
.ind-stat-lbl{font-size:12px;color:var(--muted);margin-top:2px;}

/* GLOBAL PRESENCE */
.globe-sec{background:var(--dark2);}
.globe-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;margin-top:64px;}
.globe-visual{position:relative;height:400px;display:flex;align-items:center;justify-content:center;}
.globe-canvas{width:320px;height:320px;position:relative;}
.globe-ring-outer{width:320px;height:320px;border-radius:50%;border:1px solid rgba(201,168,76,0.15);position:absolute;inset:0;animation:globeSpin 20s linear infinite;}
.globe-ring-mid{width:240px;height:240px;border-radius:50%;border:1px dashed rgba(201,168,76,0.1);position:absolute;top:40px;left:40px;animation:globeSpin 15s linear infinite reverse;}
.globe-center{width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,0.1) 0%,rgba(201,168,76,0.02) 100%);border:1px solid rgba(201,168,76,0.25);position:absolute;top:80px;left:80px;display:flex;align-items:center;justify-content:center;font-size:48px;}
@keyframes globeSpin{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
.globe-dot{position:absolute;width:8px;height:8px;border-radius:50%;background:var(--gold);box-shadow:0 0 10px rgba(201,168,76,0.6);animation:dotPulse 2s ease-in-out infinite;}
.globe-dot::after{content:'';position:absolute;inset:-4px;border-radius:50%;background:rgba(201,168,76,0.2);animation:dotPulse 2s ease-in-out infinite;}
@keyframes dotPulse{0%,100%{transform:scale(1);}50%{transform:scale(1.4);}}
.globe-city{position:absolute;font-size:10px;color:var(--gold);font-weight:600;letter-spacing:0.5px;white-space:nowrap;}
.globe-cities{display:flex;flex-direction:column;gap:18px;}
.gc-row{display:flex;align-items:center;justify-content:space-between;padding-bottom:18px;border-bottom:1px solid var(--border2);}
.gc-row:last-child{border-bottom:none;}
.gc-city{font-size:15px;font-weight:600;}
.gc-rest{font-size:13px;color:var(--muted);}
.gc-bar-wrap{width:120px;height:3px;background:var(--faint);border-radius:50px;overflow:hidden;}
.gc-bar{height:100%;border-radius:50px;background:var(--gold);}

/* TESTIMONIALS */
.test-sec{background:var(--dark);}
.test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:64px;}
.test-card{background:var(--dark2);border:1px solid var(--border2);border-radius:var(--radlg);padding:32px;transition:all .3s;position:relative;}
.test-card:hover{border-color:var(--border);transform:translateY(-3px);}
.test-quote{font-size:32px;color:var(--gold);line-height:1;margin-bottom:16px;opacity:.4;}
.test-text{font-size:15px;color:#9DA8C8;line-height:1.8;font-weight:400;margin-bottom:24px;}
.test-divider{width:32px;height:1px;background:var(--gold);margin-bottom:20px;opacity:.4;}
.test-author{display:flex;align-items:center;gap:14px;}
.test-av{width:44px;height:44px;border-radius:50%;background:rgba(201,168,76,0.1);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:var(--gold);}
.test-name{font-size:14px;font-weight:700;color:var(--text);}
.test-role{font-size:12px;color:var(--muted);margin-top:2px;}
.stars{display:flex;gap:2px;margin-bottom:16px;}
.star{width:12px;height:12px;clip-path:polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);background:var(--gold);}

/* PRICING */
.pricing-sec{background:var(--dark2);}
.price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:64px;}
.price-card{background:var(--dark3);border:1px solid var(--border2);border-radius:var(--radlg);padding:40px;position:relative;transition:all .3s;}
.price-card.featured{border-color:var(--gold);background:linear-gradient(160deg,rgba(201,168,76,0.04) 0%,var(--dark3) 60%);}
.price-card:hover{transform:translateY(-4px);}
.price-badge{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:var(--gold);color:var(--dark);font-size:11px;font-weight:800;padding:5px 16px;border-radius:50px;letter-spacing:1px;white-space:nowrap;}
.price-tier{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:var(--muted);margin-bottom:14px;}
.price-amount{font-size:48px;font-weight:900;letter-spacing:-2px;color:var(--text);line-height:1;}
.price-curr{font-size:20px;vertical-align:super;color:var(--gold);}
.price-per{font-size:14px;font-weight:400;color:var(--muted);}
.price-desc{font-size:14px;color:var(--muted);margin:14px 0 28px;line-height:1.7;}
.price-feats{list-style:none;display:flex;flex-direction:column;gap:12px;margin-bottom:32px;}
.price-feats li{display:flex;gap:10px;align-items:center;font-size:14px;color:var(--muted);}
