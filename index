<script>
// PARTICLE BACKGROUND
const canvas = document.getElementById('canvas-bg');
const ctx = canvas.getContext('2d');
let W, H, particles = [];

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

class Particle {
  constructor() { this.reset(); }
  reset() {
    this.x = Math.random() * W;
    this.y = Math.random() * H;
    this.size = Math.random() * 1.5 + 0.3;
    this.speed = Math.random() * 0.3 + 0.05;
    this.opacity = Math.random() * 0.4 + 0.05;
    this.angle = Math.random() * Math.PI * 2;
    this.drift = (Math.random() - 0.5) * 0.003;
  }
  update() {
    this.y -= this.speed;
    this.angle += this.drift;
    this.x += Math.sin(this.angle) * 0.4;
    if (this.y < -5) this.reset(), this.y = H + 5;
  }
  draw() {
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(201,168,76,${this.opacity})`;
    ctx.fill();
  }
}

for (let i = 0; i < 120; i++) particles.push(new Particle());

function animate() {
  ctx.clearRect(0, 0, W, H);
  particles.forEach(p => { p.update(); p.draw(); });
  requestAnimationFrame(animate);
}
animate();

// SCROLL PROGRESS
const prog = document.getElementById('prog');
window.addEventListener('scroll', () => {
  const s = document.documentElement.scrollTop;
  const h = document.documentElement.scrollHeight - window.innerHeight;
  prog.style.width = (s / h * 100) + '%';
});

// REVEAL ON SCROLL
const revealEls = document.querySelectorAll('.reveal, .reveal-l, .reveal-r, .tl-item');
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
}, { threshold: 0.08 });
revealEls.forEach(r => obs.observe(r));

// COUNTER ANIMATION
function animCount(el) {
  const target = parseFloat(el.dataset.target);
  const suffix = el.dataset.suffix || '';
  const dec = target % 1 !== 0 ? 1 : 0;
  const dur = 2000, step = 16;
  let cur = 0;
  const inc = target / (dur / step);
  const t = setInterval(() => {
    cur += inc;
    if (cur >= target) { cur = target; clearInterval(t); }
    el.textContent = cur.toFixed(dec) + suffix;
  }, step);
}
const statObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.querySelectorAll('[data-target]').forEach(animCount);
      statObs.unobserve(e.target);
    }
  });
}, { threshold: 0.4 });
const metricsEl = document.querySelector('.metrics-inner');
if (metricsEl) statObs.observe(metricsEl);

// BENTO MOUSE GLOW
document.querySelectorAll('.bento-card').forEach(card => {
  card.addEventListener('mousemove', e => {
    const r = card.getBoundingClientRect();
    const x = ((e.clientX - r.left) / r.width * 100).toFixed(1);
    const y = ((e.clientY - r.top) / r.height * 100).toFixed(1);
    card.style.setProperty('--mx', x + '%');
    card.style.setProperty('--my', y + '%');
  });
});

// DISH CYCLE IN PHONE
const dishes = ['🍛','🍣','🍕','🥘','🍜','🥗','🍱','🫕','🥩','🍝'];
const names  = ['Lamb Rogan Josh','Bluefin Tuna Nigiri','Truffle Margherita','Moroccan Tagine','Tokyo Ramen','Quinoa Power Bowl','Wagyu Bento','Saffron Bouillabaisse','Dry-Aged Ribeye','Squid Ink Pasta'];
let di = 0;
setInterval(() => {
  di = (di + 1) % dishes.length;
  const d = document.getElementById('p-dish');
  const n = document.getElementById('p-name');
  if (d) {
    d.style.opacity = '0';
    setTimeout(() => { d.textContent = dishes[di]; d.style.opacity = '1'; }, 300);
  }
  if (n) { n.style.opacity = '0'; setTimeout(() => { n.textContent = names[di]; n.style.opacity = '1'; }, 300); }
}, 2800);
const pDish = document.getElementById('p-dish');
const pName = document.getElementById('p-name');
if (pDish) pDish.style.transition = 'opacity .3s';
if (pName) pName.style.transition = 'opacity .3s';
</script>
