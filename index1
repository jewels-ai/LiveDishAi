<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>LiveDish AI — Premium AR Menu</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

:root{
  --gold:#d4af37;
  --gold2:#f0d77b;
  --dark:#05060b;
  --dark2:#0b0d16;
  --text:#ffffff;
  --muted:#8e95b3;
}

html{
  scroll-behavior:smooth;
}

body{
  font-family:'Inter',sans-serif;
  background:var(--dark);
  color:white;
  overflow-x:hidden;
}

/* BACKGROUND */

.bg{
  position:fixed;
  inset:0;
  background:
  radial-gradient(circle at top left, rgba(212,175,55,.08), transparent 30%),
  radial-gradient(circle at bottom right, rgba(212,175,55,.05), transparent 30%),
  #05060b;
  z-index:-3;
}

.grid{
  position:fixed;
  inset:0;
  background-image:
  linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
  linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
  background-size:60px 60px;
  mask-image:radial-gradient(circle at center, black 20%, transparent 80%);
  z-index:-2;
}

/* NAV */

nav{
  position:fixed;
  top:0;
  left:0;
  right:0;
  height:80px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:0 6%;
  background:rgba(5,6,11,.75);
  backdrop-filter:blur(20px);
  z-index:1000;
  border-bottom:1px solid rgba(255,255,255,.06);
}

.logo{
  font-size:24px;
  font-weight:800;
  letter-spacing:-1px;
}

.logo span{
  color:var(--gold);
}

.nav-links{
  display:flex;
  gap:40px;
}

.nav-links a{
  color:var(--muted);
  text-decoration:none;
  font-size:14px;
  transition:.3s;
}

.nav-links a:hover{
  color:white;
}

.nav-btn{
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  color:black;
  border:none;
  padding:14px 28px;
  border-radius:50px;
  font-weight:700;
  cursor:pointer;
  transition:.3s;
}

.nav-btn:hover{
  transform:translateY(-2px);
}

/* HERO */

.hero{
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding:140px 6%;
  position:relative;
}

.hero-content{
  max-width:1100px;
}

.tag{
  display:inline-flex;
  align-items:center;
  gap:10px;
  padding:8px 18px;
  border:1px solid rgba(212,175,55,.3);
  border-radius:50px;
  color:var(--gold);
  margin-bottom:30px;
  font-size:12px;
  letter-spacing:2px;
  text-transform:uppercase;
  background:rgba(212,175,55,.05);
  animation:fadeUp 1s ease;
}

.hero h1{
  font-size:clamp(56px,9vw,120px);
  line-height:.92;
  font-weight:900;
  letter-spacing:-4px;
  animation:fadeUp 1s ease;
}

.hero h1 span{
  color:transparent;
  -webkit-text-stroke:2px var(--gold);
}

.hero p{
  margin:30px auto;
  max-width:700px;
  color:var(--muted);
  font-size:18px;
  line-height:1.8;
  animation:fadeUp 1.2s ease;
}

.hero-buttons{
  display:flex;
  justify-content:center;
  gap:20px;
  flex-wrap:wrap;
  margin-top:40px;
}

.btn-primary{
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  color:black;
  padding:18px 36px;
  border:none;
  border-radius:60px;
  font-weight:800;
  cursor:pointer;
  transition:.35s;
  font-size:15px;
}

.btn-primary:hover{
  transform:translateY(-4px);
  box-shadow:0 20px 50px rgba(212,175,55,.3);
}

.btn-secondary{
  background:transparent;
  color:white;
  border:1px solid rgba(255,255,255,.15);
  padding:18px 36px;
  border-radius:60px;
  font-weight:600;
  cursor:pointer;
  transition:.35s;
}

.btn-secondary:hover{
  border-color:var(--gold);
  color:var(--gold);
}

/* FLOATING PHONE */

.phone-section{
  padding:120px 6%;
  display:flex;
  justify-content:center;
  align-items:center;
  position:relative;
}

.phone-wrap{
  position:relative;
}

.phone-rings span{
  position:absolute;
  border:1px solid rgba(212,175,55,.15);
  border-radius:50%;
  left:50%;
  top:50%;
  transform:translate(-50%,-50%);
  animation:ring 4s infinite;
}

.phone-rings span:nth-child(1){
  width:260px;
  height:260px;
}

.phone-rings span:nth-child(2){
  width:420px;
  height:420px;
  animation-delay:1s;
}

.phone-rings span:nth-child(3){
  width:580px;
  height:580px;
  animation-delay:2s;
}

.phone{
  width:320px;
  height:650px;
  border-radius:50px;
  border:2px solid rgba(255,255,255,.08);
  background:linear-gradient(180deg,#0c0f1d,#090b14);
  position:relative;
  overflow:hidden;
  box-shadow:
  0 40px 120px rgba(0,0,0,.8),
  inset 0 0 0 1px rgba(255,255,255,.04);
}

.notch{
  width:120px;
  height:28px;
  background:black;
  border-radius:0 0 20px 20px;
  position:absolute;
  top:0;
  left:50%;
  transform:translateX(-50%);
}

.phone-content{
  padding:34px 24px;
}

.top-row{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:30px;
}

.live{
  border:1px solid rgba(212,175,55,.3);
  color:var(--gold);
  padding:5px 14px;
  border-radius:40px;
  font-size:12px;
  background:rgba(212,175,55,.08);
}

.scan-box{
  height:280px;
  border-radius:28px;
  border:1px solid rgba(212,175,55,.18);
  background:rgba(255,255,255,.02);
  display:flex;
  justify-content:center;
  align-items:center;
  position:relative;
  overflow:hidden;
}

.corner{
  position:absolute;
  width:28px;
  height:28px;
  border-color:var(--gold);
  border-style:solid;
}

.tl{
  top:18px;
  left:18px;
  border-width:3px 0 0 3px;
}

.tr{
  top:18px;
  right:18px;
  border-width:3px 3px 0 0;
}

.bl{
  bottom:18px;
  left:18px;
  border-width:0 0 3px 3px;
}

.br{
  bottom:18px;
  right:18px;
  border-width:0 3px 3px 0;
}

.scan-line{
  position:absolute;
  width:90%;
  height:2px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
  top:0;
  left:5%;
  box-shadow:0 0 20px var(--gold);
  animation:scan 2.5s infinite ease-in-out;
}

.dish{
  font-size:110px;
  animation:floatDish 3s ease-in-out infinite;
  filter:drop-shadow(0 20px 40px rgba(212,175,55,.2));
}

.food-name{
  text-align:center;
  margin-top:30px;
  font-size:34px;
  font-weight:800;
}

.food-tags{
  display:flex;
  justify-content:center;
  gap:10px;
  flex-wrap:wrap;
  margin-top:20px;
}

.food-tags span{
  padding:8px 14px;
  border-radius:50px;
  border:1px solid rgba(212,175,55,.2);
  background:rgba(212,175,55,.05);
  color:var(--gold2);
  font-size:12px;
}

.order-btn{
  width:100%;
  margin-top:30px;
  padding:20px;
  border:none;
  border-radius:60px;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  color:black;
  font-weight:800;
  font-size:20px;
  cursor:pointer;
  transition:.3s;
}

.order-btn:hover{
  transform:scale(1.02);
}

/* FEATURES */

.features{
  padding:140px 6%;
}

.section-title{
  text-align:center;
  margin-bottom:80px;
}

.section-title h2{
  font-size:clamp(42px,6vw,72px);
  line-height:1;
  font-weight:900;
  letter-spacing:-3px;
}

.section-title p{
  color:var(--muted);
  max-width:700px;
  margin:20px auto 0;
  line-height:1.8;
}

.feature-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:24px;
}

.feature-card{
  background:linear-gradient(180deg,#0c0f1c,#090b14);
  border:1px solid rgba(255,255,255,.05);
  padding:40px;
  border-radius:30px;
  transition:.4s;
  position:relative;
  overflow:hidden;
}

.feature-card:hover{
  transform:translateY(-10px);
  border-color:rgba(212,175,55,.3);
  box-shadow:0 30px 60px rgba(0,0,0,.4);
}

.feature-card::before{
  content:'';
  position:absolute;
  inset:0;
  background:radial-gradient(circle at top right, rgba(212,175,55,.08), transparent 40%);
}

.feature-icon{
  width:70px;
  height:70px;
  border-radius:20px;
  background:rgba(212,175,55,.08);
  border:1px solid rgba(212,175,55,.2);
  display:flex;
  justify-content:center;
  align-items:center;
  font-size:30px;
  margin-bottom:24px;
}

.feature-card h3{
  font-size:24px;
  margin-bottom:14px;
}

.feature-card p{
  color:var(--muted);
  line-height:1.8;
}

/* CTA */

.cta{
  padding:140px 6%;
  text-align:center;
}

.cta-box{
  background:linear-gradient(180deg,#0c0f1d,#090b14);
  border:1px solid rgba(212,175,55,.15);
  padding:100px 40px;
  border-radius:40px;
  position:relative;
  overflow:hidden;
}

.cta-box::before{
  content:'AR';
  position:absolute;
  font-size:240px;
  font-weight:900;
  color:rgba(212,175,55,.03);
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
}

.cta h2{
  position:relative;
  z-index:2;
  font-size:clamp(40px,6vw,72px);
  line-height:1;
  letter-spacing:-3px;
}

.cta p{
  position:relative;
  z-index:2;
  max-width:700px;
  margin:30px auto;
  color:var(--muted);
  line-height:1.8;
}

.cta .btn-primary{
  position:relative;
  z-index:2;
}

/* FOOTER */

footer{
  padding:60px 6%;
  text-align:center;
  color:var(--muted);
  border-top:1px solid rgba(255,255,255,.05);
}

/* ANIMATIONS */

@keyframes floatDish{
  0%,100%{
    transform:translateY(0px) rotate(0deg);
  }
  50%{
    transform:translateY(-14px) rotate(5deg);
  }
}

@keyframes scan{
  0%{
    top:10px;
    opacity:0;
  }
  20%{
    opacity:1;
  }
  80%{
    opacity:1;
  }
  100%{
    top:250px;
    opacity:0;
  }
}

@keyframes ring{
  0%{
    transform:translate(-50%,-50%) scale(.8);
    opacity:.5;
  }
  100%{
    transform:translate(-50%,-50%) scale(1.3);
    opacity:0;
  }
}

@keyframes fadeUp{
  from{
    opacity:0;
    transform:translateY(30px);
  }
  to{
    opacity:1;
    transform:translateY(0);
  }
}

/* RESPONSIVE */

@media(max-width:768px){

  .nav-links{
    display:none;
  }

  .hero h1{
    letter-spacing:-2px;
  }

  .phone{
    width:280px;
    height:590px;
  }

  .food-name{
    font-size:28px;
  }

}

</style>
</head>

<body>

<div class="bg"></div>
<div class="grid"></div>

<!-- NAV -->

<nav>
  <div class="logo">
    Live<span>Dish</span> AI
  </div>

  <div class="nav-links">
    <a href="#">Features</a>
    <a href="#">AR Experience</a>
    <a href="#">Pricing</a>
    <a href="#">Contact</a>
  </div>

  <button class="nav-btn">
    Book Demo
  </button>
</nav>

<!-- HERO -->

<section class="hero">

  <div class="hero-content">

    <div class="tag">
      ✦ THE FUTURE OF RESTAURANT MENUS
    </div>

    <h1>
      Menus That <br>
      <span>Come Alive</span><br>
      in Augmented Reality
    </h1>

    <p>
      LiveDish AI transforms every menu into an immersive AR dining experience.
      Guests scan, explore, and order photorealistic dishes directly from their table.
    </p>

    <div class="hero-buttons">
      <button class="btn-primary">
        Start Free Demo →
      </button>

      <button class="btn-secondary">
        Watch Experience
      </button>
    </div>

  </div>

</section>

<!-- PHONE -->

<section class="phone-section">

  <div class="phone-wrap">

    <div class="phone-rings">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="phone">

      <div class="notch"></div>

      <div class="phone-content">

        <div class="top-row">
          <h3 style="color:var(--gold)">LIVEDISH AR</h3>
          <div class="live">● LIVE</div>
        </div>

        <div class="scan-box">

          <div class="corner tl"></div>
          <div class="corner tr"></div>
          <div class="corner bl"></div>
          <div class="corner br"></div>

          <div class="scan-line"></div>

          <div class="dish" id="dish">
            🍣
          </div>

        </div>

        <div class="food-name" id="foodName">
          Sushi Platter
        </div>

        <div class="food-tags">
          <span>🔥 620 kcal</span>
          <span>⭐ 4.9</span>
          <span>🌿 Fresh</span>
          <span>🚫 Gluten-Free</span>
        </div>

        <button class="order-btn" id="priceBtn">
          Add to Order — ₹890
        </button>

      </div>

    </div>

  </div>

</section>

<!-- FEATURES -->

<section class="features">

  <div class="section-title">
    <h2>
      Why Restaurants<br>
      Choose LiveDish AI
    </h2>

    <p>
      Designed for modern restaurants that want to deliver unforgettable dining experiences through AR technology.
    </p>
  </div>

  <div class="feature-grid">

    <div class="feature-card">
      <div class="feature-icon">🥽</div>
      <h3>Real-Time AR</h3>
      <p>
        Guests instantly preview life-size 3D dishes directly on their table using WebAR technology.
      </p>
    </div>

    <div class="feature-card">
      <div class="feature-icon">⚡</div>
      <h3>No App Required</h3>
      <p>
        Customers simply scan a QR code and experience immersive menus directly in the browser.
      </p>
    </div>

    <div class="feature-card">
      <div class="feature-icon">📈</div>
      <h3>Increase Orders</h3>
      <p>
        Restaurants see higher conversions and upsells because guests confidently explore dishes visually.
      </p>
    </div>

  </div>

</section>

<!-- CTA -->

<section class="cta">

  <div class="cta-box">

    <h2>
      Ready to Transform<br>
      Your Restaurant?
    </h2>

    <p>
      Join the future of dining experiences with LiveDish AI and bring your menu to life through immersive AR technology.
    </p>

    <button class="btn-primary">
      Get Started →
    </button>

  </div>

</section>

<!-- FOOTER -->

<footer>
  © 2026 LiveDish AI — All Rights Reserved
</footer>

<script>

const dishes = [
  {
    emoji:"🍣",
    name:"Sushi Platter",
    price:"₹890"
  },
  {
    emoji:"🍔",
    name:"Smash Burger",
    price:"₹420"
  },
  {
    emoji:"🍕",
    name:"Truffle Pizza",
    price:"₹780"
  },
  {
    emoji:"🍜",
    name:"Ramen Bowl",
    price:"₹540"
  },
  {
    emoji:"🍛",
    name:"Moroccan Tagine",
    price:"₹680"
  }
];

let index = 0;

setInterval(()=>{

  index = (index + 1) % dishes.length;

  document.getElementById("dish").innerHTML = dishes[index].emoji;
  document.getElementById("foodName").innerHTML = dishes[index].name;
  document.getElementById("priceBtn").innerHTML =
  `Add to Order — ${dishes[index].price}`;

},3000);

</script>

</body>
</html>