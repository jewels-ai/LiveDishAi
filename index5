<script>

const glow = document.querySelector('.cursor-glow');

window.addEventListener('mousemove',(e)=>{

glow.style.left = e.clientX + 'px';
glow.style.top = e.clientY + 'px';

});

/* FOOD ROTATION */

const foods = [

{
emoji:"🍣",
name:"Sushi Omakase",
price:"₹1290",
tags:["🔥 580 kcal","⭐ 4.9","🌿 Fresh"]
},

{
emoji:"🍕",
name:"Truffle Pizza",
price:"₹890",
tags:["🧀 Cheese","⭐ 4.8","🍄 Mushroom"]
},

{
emoji:"🍜",
name:"Tonkotsu Ramen",
price:"₹640",
tags:["🥚 Soft Egg","⭐ 4.9","🌶 Spicy"]
},

{
emoji:"🍔",
name:"Smash Burger",
price:"₹540",
tags:["🥩 Wagyu","⭐ 4.7","🔥 Grill"]
}

];

let current = 0;

setInterval(()=>{

current = (current + 1) % foods.length;

document.getElementById('foodEmoji').innerHTML =
foods[current].emoji;

document.getElementById('foodName').innerHTML =
foods[current].name;

document.getElementById('priceBtn').innerHTML =
`Add To Order — ${foods[current].price}`;

document.getElementById('foodTags').innerHTML =
foods[current].tags.map(tag=>`<span>${tag}</span>`).join('');

},3500);

</script>

