<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>LiveDish AI — Futuristic AR Dining</title>

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@500;700;800&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet"/>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

:root{
  --gold:#C9A84C;
  --gold2:#F4D98A;
  --dark:#06070D;
  --dark2:#0F121B;
  --card:rgba(18,20,35,.72);
  --text:#F8F8FC;
  --muted:#96A0BD;
}

html{
  scroll-behavior:smooth;
}

body{
  font-family:'DM Sans',sans-serif;
  background:var(--dark);
  color:var(--text);
  overflow-x:hidden;
  position:relative;
}

/* BACKGROUND */

body::before{
  content:'';
  position:fixed;
  inset:0;
  z-index:-5;

  background:
  radial-gradient(circle at 10% 10%, rgba(201,168,76,.10), transparent 25%),
  radial-gradient(circle at 90% 80%, rgba(201,168,76,.08), transparent 25%),
  linear-gradient(180deg,#06070D,#090B13);

  animation:bgMove 14s infinite alternate ease-in-out;
}

@keyframes bgMove{
  from{
    transform:scale(1) translateY(0px);
  }
  to{
    transform:scale(1.08) translateY(-20px);
  }
}

.grid{
  position:fixed;
  inset:0;
  z-index:-4;

  background-image:
  linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
  linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);

  background-size:70px 70px;

  mask-image:radial-gradient(circle at center, black 30%, transparent 80%);
}

/* CURSOR GLOW */

.cursor-glow{
  position:fixed;
  width:500px;
  height:500px;
  border-radius:50%;
  pointer-events:none;
  z-index:-2;

  background:
  radial-gradient(
    circle,
    rgba(201,168,76,.15),
    transparent 70%
  );

  transform:translate(-50%,-50%);
}

/* NAV */

nav{
  position:fixed;
  top:20px;
  left:50%;
  transform:translateX(-50%);
  width:92%;
  max-width:1300px;
  height:74px;

  display:flex;
  align-items:center;
  justify-content:space-between;

  padding:0 28px;

  z-index:1000;

  border:1px solid rgba(255,255,255,.06);

  background:rgba(12,14,22,.45);

  backdrop-filter:blur(24px);

  border-radius:24px;

  box-shadow:
  0 10px 40px rgba(0,0,0,.4);
}

.logo{
  font-family:'Syne',sans-serif;
  font-size:28px;
  font-weight:800;
}

.logo span{
  color:var(--gold);
}

.nav-links{
  display:flex;
  gap:28px;
}

.nav-links a{
  text-decoration:none;
  color:var(--muted);
  transition:.3s;
  font-size:14px;
}

.nav-links a:hover{
  color:white;
}

.nav-btn{
  padding:14px 26px;
  border:none;
  border-radius:60px;

  background:
  linear-gradient(
    135deg,
    var(--gold),
    var(--gold2)
  );

  color:black;
  font-weight:700;
  cursor:pointer;

  transition:.4s;
}

.nav-btn:hover{
  transform:translateY(-3px);
}

/* HERO */

.hero{
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding:180px 6% 120px;
  position:relative;
  overflow:hidden;
}

.hero-video{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
  opacity:.15;
}

.hero-content{
  position:relative;
  z-index:2;
  max-width:1000px;
}

.hero-badge{
  display:inline-flex;
  gap:10px;
  align-items:center;

  padding:12px 22px;

  border-radius:60px;

  border:1px solid rgba(201,168,76,.2);

  background:rgba(201,168,76,.06);

  color:var(--gold);

  margin-bottom:30px;

  font-size:12px;
  letter-spacing:2px;
}

.hero h1{
  font-family:'Syne',sans-serif;
  font-size:clamp(60px,8vw,120px);
  line-height:.92;
  letter-spacing:-4px;
}

.hero h1 span{
  color:transparent;
  -webkit-text-stroke:1.5px var(--gold);
}

.hero p{
  margin:30px auto;
  max-width:760px;
  line-height:1.9;
  color:var(--muted);
  font-size:18px;
}

.hero-buttons{
  display:flex;
  justify-content:center;
  gap:20px;
  flex-wrap:wrap;
  margin-top:40px;
}

.btn-primary{
  padding:18px 36px;
  border:none;
  border-radius:60px;

  background:
  linear-gradient(
    135deg,
    var(--gold),
    var(--gold2)
  );

  color:black;
  font-weight:700;
  cursor:pointer;

  transition:.35s;
}

.btn-primary:hover{
  transform:
  translateY(-5px)
  scale(1.03);

  box-shadow:
  0 20px 50px rgba(201,168,76,.3);
}

.btn-secondary{
  padding:18px 36px;
  border-radius:60px;
  border:1px solid rgba(255,255,255,.1);

  background:transparent;
  color:white;

  cursor:pointer;
  transition:.35s;
}

.btn-secondary:hover{
  border-color:var(--gold);
  color:var(--gold);
}

/* STATS */

.hero-stats{
  margin-top:70px;

  display:flex;
  justify-content:center;
  gap:70px;
  flex-wrap:wrap;
}

.hero-stats h3{
  font-size:44px;
  font-family:'Syne',sans-serif;
  color:var(--gold);
}

.hero-stats span{
  color:var(--muted);
  font-size:14px;
}

/* PHONE */

.phone-section{
  padding:120px 6%;
  display:flex;
  justify-content:center;
}

.phone-wrap{
  position:relative;
}

.phone-glow{
  position:absolute;
  width:550px;
  height:550px;
  border-radius:50%;

  background:
  radial-gradient(
    circle,
    rgba(201,168,76,.18),
    transparent 70%
  );

  top:50%;
  left:50%;
  transform:translate(-50%,-50%);

  animation:pulseGlow 5s infinite;
}

.phone{
  width:330px;
  height:680px;

  border-radius:50px;

  background:
  linear-gradient(
    180deg,
    #101321,
    #090B14
  );

  border:1px solid rgba(255,255,255,.08);

  overflow:hidden;
  position:relative;

  box-shadow:
  0 50px 100px rgba(0,0,0,.7);

  animation:phoneFloat 5s ease-in-out infinite;
}

.notch{
  width:120px;
  height:28px;
  background:black;

  border-radius:0 0 20px 20px;

  position:absolute;
  left:50%;
  transform:translateX(-50%);
}

.phone-content{
  padding:36px 24px;
}

.scan-box{
  height:340px;
  border-radius:30px;

  border:1px solid rgba(201,168,76,.15);

  position:relative;

  display:flex;
  align-items:center;
  justify-content:center;

  overflow:hidden;

  margin-top:30px;

  background:rgba(255,255,255,.02);
}

.qr-overlay{
  position:absolute;
  inset:0;

  background:
  repeating-linear-gradient(
    transparent 0 10px,
    rgba(201,168,76,.03) 10px 20px
  );

  animation:qrMove 2s linear infinite;
}

.scan-line{
  position:absolute;
  width:90%;
  height:2px;

  background:
  linear-gradient(
    90deg,
    transparent,
    var(--gold),
    transparent
  );

  left:5%;

  box-shadow:0 0 20px var(--gold);

  animation:scan 2.5s infinite;
}

.food{
  font-size:110px;
  z-index:2;

  animation:dishFloat 3s infinite ease-in-out;
}

.food-name{
  text-align:center;
  margin-top:26px;

  font-size:30px;
  font-family:'Syne',sans-serif;
}

.tags{
  display:flex;
  flex-wrap:wrap;
  justify-content:center;
  gap:10px;
  margin-top:18px;
}

.tags span{
  padding:8px 14px;
  border-radius:60px;

  border:1px solid rgba(201,168,76,.15);

  background:rgba(201,168,76,.06);

  color:var(--gold2);

  font-size:12px;
}

.order-btn{
  width:100%;
  padding:18px;
  margin-top:26px;

  border:none;
  border-radius:60px;

  background:
  linear-gradient(
    135deg,
    var(--gold),
    var(--gold2)
  );

  color:black;
  font-weight:700;
  font-size:18px;
}

/* SECTION */

.section{
  padding:130px 6%;
}

.section-title{
  text-align:center;
  margin-bottom:70px;
}

.section-title h2{
  font-size:clamp(42px,6vw,78px);
  font-family:'Syne',sans-serif;
  line-height:1;
  letter-spacing:-2px;
}

/* CARDS */

.cards{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:28px;
}

.card{
  background:var(--card);

  border:1px solid rgba(255,255,255,.05);

  border-radius:30px;

  overflow:hidden;

  backdrop-filter:blur(18px);

  transition:.45s;

  transform-style:preserve-3d;
}

.card:hover{
  transform:
  rotateX(6deg)
  rotateY(-6deg)
  translateY(-10px);

  border-color:rgba(201,168,76,.25);

  box-shadow:
  0 30px 60px rgba(0,0,0,.45);
}

.card img{
  width:100%;
  height:240px;
  object-fit:cover;

  transition:.5s;
}

.card:hover img{
  transform:scale(1.08);
}

.card-content{
  padding:28px;
}

.card h3{
  font-size:28px;
  font-family:'Syne',sans-serif;
  margin-bottom:14px;
}

.card p{
  color:var(--muted);
  line-height:1.8;
}

/* FEATURES */

.feature-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:30px;
}

.feature{
  padding:40px;
  border-radius:30px;

  background:var(--card);

  border:1px solid rgba(255,255,255,.05);

  backdrop-filter:blur(18px);

  transition:.4s;
}

.feature:hover{
  transform:translateY(-10px);

  border-color:rgba(201,168,76,.25);

  box-shadow:
  0 20px 50px rgba(0,0,0,.45);
}

.feature-icon{
  width:72px;
  height:72px;

  border-radius:22px;

  display:flex;
  align-items:center;
  justify-content:center;

  font-size:32px;

  margin-bottom:24px;

  background:rgba(255,255,255,.04);

  border:1px solid rgba(255,255,255,.08);
}

.feature h3{
  font-size:24px;
  margin-bottom:14px;
  font-family:'Syne',sans-serif;
}

.feature p{
  color:var(--muted);
  line-height:1.8;
}

/* VOICE AI */

.voice-box{
  max-width:700px;
  margin:auto;

  padding:60px;

  border-radius:40px;

  background:var(--card);

  border:1px solid rgba(255,255,255,.06);

  text-align:center;
}

.wave{
  width:180px;
  height:180px;
  margin:auto auto 30px;

  border-radius:50%;

  border:2px solid rgba(201,168,76,.25);

  animation:pulseWave 2s infinite;
}

.voice-box p{
  margin-bottom:30px;
  color:var(--muted);
  font-size:20px;
}

/* DASHBOARD */

.dashboard{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:30px;
}

.metric{
  padding:40px;
  border-radius:30px;

  background:var(--card);

  border:1px solid rgba(255,255,255,.05);

  text-align:center;
}

.metric h3{
  font-size:54px;
  color:var(--gold);
  font-family:'Syne',sans-serif;
}

.metric p{
  margin-top:10px;
  color:var(--muted);
}

/* MARQUEE */

.marquee{
  overflow:hidden;
  white-space:nowrap;
  position:relative;
}

.marquee-track{
  display:inline-flex;
  gap:80px;

  animation:marquee 18s linear infinite;
}

.marquee span{
  font-size:34px;
  color:rgba(255,255,255,.2);
  font-family:'Syne',sans-serif;
}

/* CTA */

.cta{
  padding:140px 6%;
}

.cta-box{
  padding:100px 40px;
  border-radius:40px;

  background:
  linear-gradient(
    180deg,
    #0D101B,
    #090B13
  );

  border:1px solid rgba(201,168,76,.1);

  text-align:center;
}

.cta h2{
  font-size:clamp(46px,6vw,84px);
  font-family:'Syne',sans-serif;
  line-height:1;
}

.cta p{
  max-width:700px;
  margin:30px auto 40px;
  color:var(--muted);
  line-height:1.9;
}

/* FOOTER */

footer{
  padding:50px;
  text-align:center;
  color:var(--muted);
  border-top:1px solid rgba(255,255,255,.05);
}

/* ANIMATION */

@keyframes phoneFloat{
  0%,100%{
    transform:translateY(0px);
  }
  50%{
    transform:translateY(-12px);
  }
}

@keyframes pulseGlow{
  0%,100%{
    transform:translate(-50%,-50%) scale(1);
  }
  50%{
    transform:translate(-50%,-50%) scale(1.18);
  }
}

@keyframes dishFloat{
  0%,100%{
    transform:translateY(0px);
  }
  50%{
    transform:translateY(-12px);
  }
}

@keyframes scan{
  0%{
    top:0;
  }
  100%{
    top:100%;
  }
}

@keyframes qrMove{
  from{
    transform:translateY(0);
  }
  to{
    transform:translateY(20px);
  }
}

@keyframes pulseWave{
  0%{
    transform:scale(.9);
    opacity:.5;
  }
  100%{
    transform:scale(1.2);
    opacity:0;
  }
}

@keyframes marquee{
  from{
    transform:translateX(0);
  }
  to{
    transform:translateX(-50%);
  }
}

/* MOBILE */

@media(max-width:768px){

  .nav-links{
    display:none;
  }

  .hero{
    padding-top:160px;
  }

  .hero h1{
    font-size:52px;
    line-height:1;
  }

  .hero p{
    font-size:15px;
  }

  .hero-buttons{
    flex-direction:column;
  }

  .btn-primary,
  .btn-secondary{
    width:100%;
  }

  .phone{
    width:290px;
    height:620px;
  }

  .food{
    font-size:80px;
  }

  .food-name{
    font-size:24px;
  }

  .voice-box{
    padding:40px 24px;
  }

}

</style>
</head>

