<script>
// CURSOR
const cursor = document.getElementById('cursor');
const cursorRing = document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cursor.style.left=mx+'px';cursor.style.top=my+'px';
});
function animateRing(){
  rx+=(mx-rx)*0.12;ry+=(my-ry)*0.12;
  cursorRing.style.left=rx+'px';cursorRing.style.top=ry+'px';
  requestAnimationFrame(animateRing);
}
animateRing();

// DISH CAROUSEL
const dishes=[
  {emoji:'🍣',name:'Sushi Platter',price:'₹890',meta:['🔥 620 kcal','⭐ 4.9','🚫 Gluten-Free']},
  {emoji:'🍔',name:'Smash Burger',price:'₹420',meta:['🔥 890 kcal','⭐ 4.7','🌿 Grass-Fed']},
  {emoji:'🍕',name:'Truffle Pizza',price:'₹780',meta:['🔥 740 kcal','⭐ 4.8','🧀 Vegetarian']},
  {emoji:'🍜',name:'Wagyu Ramen',price:'₹680',meta:['🔥 560 kcal','⭐ 4.9','🌶 Spicy']},
  {emoji:'🍛',name:'Moroccan Tagine',price:'₹540',meta:['🔥 480 kcal','⭐ 4.6','🥗 Halal']},
];
let idx=0;
const dotsEl=document.getElementById('carouselDots');
dishes.forEach((_,i)=>{
  const d=document.createElement('div');
  d.className='dot'+(i===0?' active':'');
  dotsEl.appendChild(d);
});
function updateDots(){
  document.querySelectorAll('.dot').forEach((d,i)=>{
    d.classList.toggle('active',i===idx);
  });
}
function nextDish(){
  idx=(idx+1)%dishes.length;
  const d=dishes[idx];
  const emojiEl=document.getElementById('dishEmoji');
  const titleEl=document.getElementById('dishTitle');
  const metaEl=document.getElementById('dishMeta');
  const btnEl=document.getElementById('orderBtn');
  emojiEl.style.opacity='0';emojiEl.style.transform='scale(0.7)';
  titleEl.style.opacity='0';
  setTimeout(()=>{
    emojiEl.textContent=d.emoji;
    titleEl.textContent=d.name;
    metaEl.innerHTML=d.meta.map(m=>`<span class="tag-pill">${m}</span>`).join('');
    btnEl.textContent=`Add to Order — ${d.price}`;
    emojiEl.style.opacity='1';emojiEl.style.transform='';
    titleEl.style.opacity='1';
  },280);
  updateDots();
}
setInterval(nextDish,3200);

// SCROLL REVEAL
const revealEls=document.querySelectorAll('.reveal');
const observer=new IntersectionObserver(entries=>{
  entries.forEach((e,i)=>{
    if(e.isIntersecting){
      setTimeout(()=>e.target.classList.add('visible'),i*60);
      observer.unobserve(e.target);
    }
  });
},{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
revealEls.forEach(el=>observer.observe(el));
</script>
