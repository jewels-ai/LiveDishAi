<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>LiveDish AI — Premium AR Menu Experience</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;}

:root{
  --gold:#d4af37;
  --gold2:#f5e08b;
  --gold-dark:#a07c1a;
  --dark:#04050c;
  --dark2:#080a14;
  --dark3:#0c0e1c;
  --text:#ffffff;
  --muted:#6e7590;
  --muted2:#9aa0bb;
  --card:#090b17;
  --border:rgba(255,255,255,0.06);
  --gold-border:rgba(212,175,55,0.25);
}

html{scroll-behavior:smooth;}

body{
  font-family:'DM Sans',sans-serif;
  background:var(--dark);
  color:white;
  overflow-x:hidden;
  cursor:none;
}

/* CUSTOM CURSOR */
.cursor{
  position:fixed;
  width:10px;height:10px;
  background:var(--gold);
  border-radius:50%;
  pointer-events:none;
  z-index:9999;
  transform:translate(-50%,-50%);
  transition:transform 0.08s ease;
  mix-blend-mode:difference;
}
.cursor-ring{
  position:fixed;
  width:38px;height:38px;
  border:1.5px solid rgba(212,175,55,0.5);
  border-radius:50%;
  pointer-events:none;
  z-index:9998;
  transform:translate(-50%,-50%);
  transition:transform 0.18s ease, width 0.3s, height 0.3s, opacity 0.3s;
}
body:has(button:hover) .cursor-ring,
body:has(a:hover) .cursor-ring{
  width:60px;height:60px;
  opacity:0.5;
}

/* NOISE OVERLAY */
.noise{
  position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events:none;z-index:0;opacity:0.4;
}

/* BG */
.bg{
  position:fixed;inset:0;
  background:
    radial-gradient(ellipse 60% 50% at 10% 0%, rgba(212,175,55,0.07) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 90% 100%, rgba(212,175,55,0.04) 0%, transparent 60%),
    #04050c;
  z-index:-3;
}
.grid{
  position:fixed;inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
  background-size:50px 50px;
  mask-image:radial-gradient(ellipse 80% 80% at center, black 0%, transparent 80%);
  z-index:-2;
}

/* NAV */
nav{
  position:fixed;top:0;left:0;right:0;height:76px;
  display:flex;justify-content:space-between;align-items:center;
  padding:0 5%;
  background:rgba(4,5,12,0.8);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  z-index:1000;
  border-bottom:1px solid var(--border);
}
.logo{
  font-family:'Syne',sans-serif;
  font-size:22px;font-weight:800;letter-spacing:-0.5px;
  display:flex;align-items:center;gap:10px;
}
.logo-icon{
  width:36px;height:36px;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;
}
.logo span{color:var(--gold);}
.nav-links{display:flex;gap:36px;}
.nav-links a{
  color:var(--muted2);text-decoration:none;font-size:14px;
  font-weight:500;transition:.3s;position:relative;
}
.nav-links a::after{
  content:'';position:absolute;bottom:-4px;left:0;
  width:0;height:1.5px;background:var(--gold);
  transition:.3s;
}
.nav-links a:hover{color:white;}
.nav-links a:hover::after{width:100%;}
.nav-right{display:flex;align-items:center;gap:16px;}
.nav-badge{
  font-size:11px;font-weight:600;
  background:rgba(212,175,55,0.12);
  border:1px solid var(--gold-border);
  color:var(--gold2);
  padding:5px 12px;border-radius:50px;
  letter-spacing:0.5px;
}
.nav-btn{
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  color:#000;border:none;padding:12px 26px;
  border-radius:50px;font-weight:700;cursor:none;
  font-size:13px;letter-spacing:0.3px;
  transition:.3s;font-family:'Syne',sans-serif;
}
.nav-btn:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(212,175,55,0.25);}

/* HERO */
.hero{
  min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  text-align:center;padding:120px 5% 80px;
  position:relative;z-index:1;
}
.hero-content{max-width:1000px;}

.eyebrow{
  display:inline-flex;align-items:center;gap:10px;
  padding:8px 20px;
  border:1px solid var(--gold-border);
  border-radius:50px;color:var(--gold2);
  margin-bottom:36px;font-size:11px;
  letter-spacing:2px;text-transform:uppercase;
  background:rgba(212,175,55,0.06);
  font-weight:600;
  animation:fadeUp .9s ease both;
}
.eyebrow-dot{
  width:6px;height:6px;border-radius:50%;
  background:var(--gold);
  box-shadow:0 0 8px var(--gold);
  animation:pulse 2s infinite;
}

.hero h1{
  font-family:'Syne',sans-serif;
  font-size:clamp(52px,8.5vw,108px);
  line-height:.93;font-weight:800;
  letter-spacing:-3px;
  animation:fadeUp 1s ease .1s both;
}
.hero h1 em{
  font-style:normal;color:transparent;
  -webkit-text-stroke:1.5px var(--gold);
  display:inline-block;
  position:relative;
}
.hero h1 em::after{
  content:attr(data-text);
  position:absolute;inset:0;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  opacity:0;
  animation:shimmerReveal 3s 1.5s ease forwards;
}
.hero-sub{
  margin:28px auto 0;max-width:640px;
  color:var(--muted2);font-size:17px;line-height:1.85;
  font-weight:300;
  animation:fadeUp 1s ease .2s both;
}
.hero-btns{
  display:flex;justify-content:center;gap:16px;
  flex-wrap:wrap;margin-top:44px;
  animation:fadeUp 1s ease .3s both;
}
.btn-primary{
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  color:#000;padding:17px 36px;
  border:none;border-radius:60px;
  font-weight:700;cursor:none;
  font-size:15px;letter-spacing:0.2px;
  transition:.35s;font-family:'Syne',sans-serif;
  display:flex;align-items:center;gap:10px;
}
.btn-primary:hover{transform:translateY(-4px);box-shadow:0 24px 60px rgba(212,175,55,.3);}
.btn-secondary{
  background:transparent;color:white;
  border:1px solid rgba(255,255,255,.12);
  padding:17px 36px;border-radius:60px;
  font-weight:500;cursor:none;transition:.35s;font-size:15px;
  display:flex;align-items:center;gap:10px;
}
.btn-secondary:hover{border-color:var(--gold);color:var(--gold);}

/* STATS ROW */
.stats{
  display:flex;justify-content:center;gap:0;
  margin-top:64px;
  animation:fadeUp 1s ease .4s both;
}
.stat{
  padding:0 40px;
  border-right:1px solid var(--border);
  text-align:center;
}
.stat:last-child{border-right:none;}
.stat-num{
  font-family:'Syne',sans-serif;
  font-size:32px;font-weight:800;
  color:var(--gold2);letter-spacing:-1px;
}
.stat-label{color:var(--muted);font-size:12px;margin-top:4px;font-weight:400;}

/* PHONE SECTION */
.phone-section{
  padding:100px 5%;
  display:flex;justify-content:center;align-items:center;
  position:relative;z-index:1;
}
.phone-wrap{position:relative;display:flex;align-items:center;gap:60px;flex-wrap:wrap;justify-content:center;}

.phone-info{max-width:360px;}
.phone-info h3{
  font-family:'Syne',sans-serif;
  font-size:clamp(32px,5vw,52px);
  font-weight:800;letter-spacing:-2px;
  line-height:1.05;margin-bottom:20px;
}
.phone-info p{color:var(--muted2);line-height:1.8;font-size:15px;margin-bottom:28px;}
.phone-feature-list{display:flex;flex-direction:column;gap:14px;}
.phone-feat{
  display:flex;align-items:center;gap:14px;
  background:rgba(255,255,255,.02);
  border:1px solid var(--border);
  padding:14px 18px;border-radius:14px;
  transition:.3s;
}
.phone-feat:hover{border-color:var(--gold-border);background:rgba(212,175,55,.04);}
.phone-feat-icon{
  width:38px;height:38px;border-radius:10px;
  background:rgba(212,175,55,.08);
  border:1px solid var(--gold-border);
  display:flex;align-items:center;justify-content:center;
  font-size:18px;flex-shrink:0;
}
.phone-feat-text{font-size:14px;font-weight:500;}
.phone-feat-sub{font-size:12px;color:var(--muted);margin-top:2px;}

/* RINGS + PHONE */
.phone-device-wrap{position:relative;}
.rings span{
  position:absolute;border:1px solid rgba(212,175,55,0.12);
  border-radius:50%;left:50%;top:50%;
  transform:translate(-50%,-50%);animation:ring 5s infinite;
}
.rings span:nth-child(1){width:300px;height:300px;}
.rings span:nth-child(2){width:440px;height:440px;animation-delay:1.5s;}
.rings span:nth-child(3){width:600px;height:600px;animation-delay:3s;}

.phone{
  width:300px;height:620px;
  border-radius:48px;
  border:1.5px solid rgba(255,255,255,0.07);
  background:linear-gradient(175deg,#0d1022,#080a14);
  position:relative;overflow:hidden;
  box-shadow:
    0 60px 120px rgba(0,0,0,.9),
    0 0 0 1px rgba(255,255,255,0.03),
    inset 0 1px 0 rgba(255,255,255,0.07);
  animation:phoneFloat 6s ease-in-out infinite;
}
.notch{
  width:100px;height:26px;
  background:#000;border-radius:0 0 18px 18px;
  position:absolute;top:0;left:50%;transform:translateX(-50%);
  z-index:10;display:flex;align-items:center;justify-content:center;gap:8px;
}
.notch-cam{width:8px;height:8px;background:#1a1a1a;border-radius:50%;}
.notch-speaker{width:40px;height:4px;background:#1a1a1a;border-radius:4px;}

.phone-ui{padding:32px 18px 20px;}
.phone-header{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:18px;
}
.phone-app-name{
  font-family:'Syne',sans-serif;font-weight:700;
  font-size:14px;color:var(--gold);letter-spacing:.5px;
}
.live-pill{
  display:flex;align-items:center;gap:6px;
  border:1px solid rgba(212,175,55,0.3);
  color:var(--gold2);padding:4px 12px;
  border-radius:40px;font-size:11px;font-weight:600;
  background:rgba(212,175,55,0.08);
}
.live-dot{width:5px;height:5px;border-radius:50%;background:var(--gold);animation:pulse 1.5s infinite;}

.scan-area{
  height:260px;border-radius:24px;
  border:1px solid rgba(212,175,55,0.15);
  background:rgba(255,255,255,0.015);
  position:relative;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
}
.corner{position:absolute;width:24px;height:24px;border-color:var(--gold);border-style:solid;}
.tl{top:14px;left:14px;border-width:2.5px 0 0 2.5px;border-radius:4px 0 0 0;}
.tr{top:14px;right:14px;border-width:2.5px 2.5px 0 0;border-radius:0 4px 0 0;}
.bl{bottom:14px;left:14px;border-width:0 0 2.5px 2.5px;border-radius:0 0 0 4px;}
.br{bottom:14px;right:14px;border-width:0 2.5px 2.5px 0;border-radius:0 0 4px 0;}
.scan-line{
  position:absolute;width:86%;height:1.5px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
  left:7%;box-shadow:0 0 16px var(--gold);
  animation:scanLine 2.5s infinite ease-in-out;
}
.dish-emoji{
  font-size:90px;
  animation:dishFloat 3s ease-in-out infinite;
  filter:drop-shadow(0 10px 30px rgba(212,175,55,.25));
  transition:all 0.4s ease;
}
.dish-glow{
  position:absolute;
  width:120px;height:60px;
  background:rgba(212,175,55,0.12);
  border-radius:50%;
  bottom:20px;filter:blur(16px);
  animation:glowPulse 3s ease-in-out infinite;
}

.dish-title{
  font-family:'Syne',sans-serif;
  font-size:26px;font-weight:800;
  text-align:center;margin-top:18px;
  letter-spacing:-.5px;
  transition:all .4s ease;
}
.dish-meta{
  display:flex;justify-content:center;gap:8px;flex-wrap:wrap;
  margin-top:12px;
}
.tag-pill{
  padding:5px 11px;border-radius:40px;
  border:1px solid rgba(212,175,55,.2);
  background:rgba(212,175,55,.04);
  color:var(--gold2);font-size:10px;font-weight:500;
}
.order-btn{
  width:100%;margin-top:16px;padding:16px;
  border:none;border-radius:50px;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  color:#000;font-weight:700;font-size:15px;
  cursor:none;transition:.3s;
  font-family:'Syne',sans-serif;letter-spacing:.2px;
}
.order-btn:hover{transform:scale(1.02);}
.dish-carousel-dots{
  display:flex;justify-content:center;gap:6px;margin-top:12px;
}
.dot{
  width:5px;height:5px;border-radius:50%;
  background:rgba(255,255,255,.15);transition:.3s;
}
.dot.active{background:var(--gold);width:16px;border-radius:4px;}

/* MARQUEE */
.marquee-section{
  padding:40px 0;overflow:hidden;
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
  background:rgba(255,255,255,.01);
  position:relative;z-index:1;
}
.marquee-track{
  display:flex;gap:60px;
  animation:marquee 20s linear infinite;
  width:max-content;
}
.marquee-item{
  display:flex;align-items:center;gap:14px;
  color:var(--muted);font-size:13px;font-weight:500;
  letter-spacing:.5px;text-transform:uppercase;white-space:nowrap;
}
.marquee-item span{color:var(--gold);font-size:18px;}

/* HOW IT WORKS */
.how{padding:130px 5%;position:relative;z-index:1;}
.section-label{
  display:inline-flex;align-items:center;gap:8px;
  font-size:11px;letter-spacing:2.5px;text-transform:uppercase;
  color:var(--gold);font-weight:600;margin-bottom:20px;
}
.section-label::before{
  content:'';width:24px;height:1.5px;background:var(--gold);
}
.section-h{
  font-family:'Syne',sans-serif;
  font-size:clamp(40px,6vw,68px);
  font-weight:800;letter-spacing:-2.5px;line-height:1;
  margin-bottom:20px;
}
.section-p{color:var(--muted2);max-width:600px;line-height:1.85;font-size:15px;}

.steps{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:24px;margin-top:70px;
}
.step{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:28px;padding:40px 36px;
  position:relative;overflow:hidden;
  transition:.4s cubic-bezier(.23,1,.32,1);
}
.step:hover{
  transform:translateY(-12px);
  border-color:var(--gold-border);
  box-shadow:0 40px 80px rgba(0,0,0,.5),0 0 0 1px rgba(212,175,55,.1);
}
.step-num{
  font-family:'Syne',sans-serif;
  font-size:72px;font-weight:800;
  color:rgba(212,175,55,.06);
  position:absolute;top:-12px;right:20px;
  line-height:1;letter-spacing:-4px;
}
.step-icon{
  width:60px;height:60px;border-radius:18px;
  background:rgba(212,175,55,.07);
  border:1px solid rgba(212,175,55,.15);
  display:flex;align-items:center;justify-content:center;
  font-size:26px;margin-bottom:24px;
}
.step h3{
  font-family:'Syne',sans-serif;
  font-size:22px;font-weight:700;margin-bottom:12px;letter-spacing:-.3px;
}
.step p{color:var(--muted2);line-height:1.8;font-size:14px;}
.step-bar{
  position:absolute;bottom:0;left:0;right:0;
  height:3px;
  background:linear-gradient(90deg,var(--gold),var(--gold2));
  transform:scaleX(0);transform-origin:left;
  transition:.4s cubic-bezier(.23,1,.32,1);
}
.step:hover .step-bar{transform:scaleX(1);}

/* FEATURES */
.features{padding:130px 5%;position:relative;z-index:1;}
.feature-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:20px;margin-top:70px;
}
.fc{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:24px;padding:36px;
  position:relative;overflow:hidden;
  transition:.4s cubic-bezier(.23,1,.32,1);
}
.fc::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at top right,rgba(212,175,55,.06),transparent 50%);
  opacity:0;transition:.4s;
}
.fc:hover{transform:translateY(-8px);border-color:var(--gold-border);}
.fc:hover::before{opacity:1;}
.fc-icon{
  width:56px;height:56px;border-radius:16px;
  background:rgba(212,175,55,.07);
  border:1px solid rgba(212,175,55,.15);
  display:flex;align-items:center;justify-content:center;
  font-size:24px;margin-bottom:22px;
}
.fc h3{
  font-family:'Syne',sans-serif;
  font-size:20px;font-weight:700;margin-bottom:12px;letter-spacing:-.3px;
}
.fc p{color:var(--muted2);line-height:1.8;font-size:14px;}
.fc-tag{
  display:inline-block;margin-top:18px;
  font-size:11px;font-weight:600;
  background:rgba(212,175,55,.08);
  border:1px solid rgba(212,175,55,.15);
  color:var(--gold2);padding:4px 12px;border-radius:40px;
  letter-spacing:.5px;
}

/* TESTIMONIALS */
.testimonials{padding:100px 5%;position:relative;z-index:1;}
.testi-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:20px;margin-top:60px;
}
.testi{
  background:var(--card);border:1px solid var(--border);
  border-radius:24px;padding:32px;transition:.3s;
}
.testi:hover{border-color:var(--gold-border);transform:translateY(-4px);}
.testi-stars{display:flex;gap:4px;margin-bottom:18px;}
.testi-stars span{font-size:14px;}
.testi q{
  font-size:15px;line-height:1.8;color:var(--muted2);
  font-style:italic;font-weight:300;
}
.testi-author{
  display:flex;align-items:center;gap:12px;margin-top:24px;
  padding-top:20px;border-top:1px solid var(--border);
}
.testi-avatar{
  width:42px;height:42px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:20px;
  background:rgba(212,175,55,.1);
  border:1px solid rgba(212,175,55,.2);
}
.testi-name{font-weight:600;font-size:14px;}
.testi-role{font-size:12px;color:var(--muted);}

/* PRICING */
.pricing{padding:130px 5%;position:relative;z-index:1;}
.pricing-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:20px;margin-top:60px;max-width:1000px;margin-left:auto;margin-right:auto;
}
.plan{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:28px;padding:40px 36px;
  position:relative;transition:.4s;
}
.plan:hover{transform:translateY(-6px);}
.plan.featured{
  border-color:var(--gold-border);
  background:linear-gradient(160deg,#0e1124,#090b16);
  box-shadow:0 0 0 1px rgba(212,175,55,.12),0 40px 80px rgba(0,0,0,.4);
}
.plan-badge{
  position:absolute;top:-14px;left:50%;transform:translateX(-50%);
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  color:#000;font-size:11px;font-weight:800;
  padding:5px 18px;border-radius:50px;letter-spacing:.8px;
  font-family:'Syne',sans-serif;
}
.plan-name{
  font-family:'Syne',sans-serif;font-size:16px;
  font-weight:700;color:var(--muted2);letter-spacing:.5px;
  text-transform:uppercase;margin-bottom:14px;
}
.plan-price{
  font-family:'Syne',sans-serif;
  font-size:52px;font-weight:800;
  letter-spacing:-2px;line-height:1;
}
.plan-price sup{font-size:24px;letter-spacing:0;font-weight:500;color:var(--gold);}
.plan-period{color:var(--muted);font-size:13px;margin-top:6px;}
.plan-divider{height:1px;background:var(--border);margin:28px 0;}
.plan-features{display:flex;flex-direction:column;gap:14px;}
.plan-feat{
  display:flex;align-items:center;gap:12px;
  font-size:14px;color:var(--muted2);
}
.plan-feat::before{
  content:'✓';color:var(--gold);font-weight:700;flex-shrink:0;
